{
  "manifest_version": 2,
  "name": "Smart Notes",
  "version": "1.0.0",
  "description": "Send highlighted text directly to your Smart Notes AI knowledge base.",
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-notes@extension",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "notifications",
    "activeTab",
    "http://localhost:3000/*"
  ],
  "background": {
    "scripts": ["background.js"]
  }
}
