{
  "manifest_version": 3,
  "name": "Falcon Smart Notes",
  "version": "1.0.0",
  "description": "Send highlighted text directly to your local Falcon Notes AI knowledge base.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://smart-falcon-notes.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
